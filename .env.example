# BPW Defence Tender Radar — Backend env (Python pipeline)
# ------------------------------------------------------------
# Diese Datei ist ein TEMPLATE. Echte Werte gehören in:
#   ~/Documents/02_Tender Radar/.env.local       (zentraler Master)
# ODER, für lokale Overrides nur in diesem Repo:
#   ted-scraper/ted-scraper/.env                 (nicht committen!)
#
# Lade-Reihenfolge siehe src/env_loader.py.
# Alle LLM-Calls via OpenRouter; Anthropic-Direkt-Zugang entfernt.

# OpenRouter API Key — holen unter https://openrouter.ai/keys
LLM_OPENROUTER_API_KEY=

# Default-Modell. Notation <provider>/<model>.
# Empfehlung Zuverlässigkeit:    anthropic/claude-sonnet-4.6
# Günstiger für Massendurchsatz: anthropic/claude-haiku-4.5
LLM_MODEL_NAME=anthropic/claude-sonnet-4.6

# SSL-Verify abschalten für hartnäckige nationale Portale (Corporate VPN).
SSL_VERIFY_DISABLE=1

# UK Defence Sourcing Portal (contracts.mod.uk)
UK_DSP_USERNAME=
UK_DSP_PASSWORD=

# Germany evergabe-online.de (BAAINBw / Bundeswehr e-procurement)
DE_EVERGABE_USERNAME=
DE_EVERGABE_PASSWORD=
