# .env.example — copy to .env and fill in your values (.env is gitignored)

# ── Required ──────────────────────────────────────────────────────────────────
# OpenRouter API key — all LLM calls (classification, enrichment, quality review)
# route through OpenRouter. Get a key at https://openrouter.ai/keys
LLM_OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Default model (OpenRouter model ID). Change to switch models globally.
LLM_MODEL_NAME=anthropic/claude-sonnet-4.6

# ── SSL workaround ────────────────────────────────────────────────────────────
# Required on corporate VPN/proxy — disables certificate verification
SSL_VERIFY_DISABLE=1

# ── Portal Credentials ────────────────────────────────────────────────────────
# Leave empty to use public/anonymous access (may limit results).
# When set, the corresponding adapter logs in for full notice access.

# UK Defence Sourcing Portal (contracts.mod.uk)
UK_DSP_USERNAME=
UK_DSP_PASSWORD=

# Germany evergabe-online.de (BAAINBw / Bundeswehr e-procurement)
DE_EVERGABE_USERNAME=
DE_EVERGABE_PASSWORD=
