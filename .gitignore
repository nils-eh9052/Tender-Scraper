# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# Raw data (too large for Git — rebuilt on each run)
data/raw/details/*
!data/raw/details/.gitkeep
data/raw/fulltext/*
!data/raw/fulltext/.gitkeep
data/raw/notice_index.json
data/raw/api_sample.json
data/raw/api_discovery_report.json
data/raw/probe_*.json
data/raw/cz/*.pdf

# Large adapter output directories (rebuilt on each run)
data/au_ocds_raw/
data/canada/
data/documents/
data/ted_xml_cache/
data/snapshots/

# Backup files
*.bak

# Debug HTML and probe outputs
data/*.html

# Filtered data (rebuilt on each run)
data/filtered/*
!data/filtered/.gitkeep

# Export archives and test outputs (only LATEST stays)
data/export/archive/*
!data/export/archive/.gitkeep
data/export/test/*
!data/export/test/.gitkeep

# Cache files (persisted via GitHub Actions cache, not in repo)
data/.checkpoint.json
data/.enrichment_log.json
data/.enrichment_log_v1_backup.json
data/.enrichment_fulltext_log.json
data/.award_match_log.json
data/.last_run.json
data/.filter_cache.json

# Logs and sprint artifacts
data/pipeline_*.log
data/*.log
data/.run_log/
data/.backups/
data/root_cause_analysis.md
data/sprint*_summary.md
data/sprint*_run.log
data/classify_run_*.log

# Playwright debug screenshots (rebuilt by adapters; large, not needed in repo)
data/raw/screenshots/*
!data/raw/screenshots/.gitkeep

# Adapter and review debug output
data/adapter_status.json
data/opus_review_latest.json

# Historical status reports (superseded by CLAUDE.md)
SYSTEM_STATUS_V3.md

# Environment
.env
*.env
.env.local

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Excel temp/lock files
~$*.xlsx

# Legacy (deleted)
Vorlage.xlsx.bak
SYSTEM_STATUS_REPORT.md
SYSTEM_STATUS_V2.md

# Claude Code local settings
.claude/
